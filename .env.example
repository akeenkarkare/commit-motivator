# Copy to .env and fill in your values.
# Required.
GITHUB_USER=your-github-username

# Comma-separated list of hostnames to block in /etc/hosts when no commit today.
# Default blocks Gmail. Add/remove as you wish (e.g. twitter.com,x.com,reddit.com).
BLOCKED_HOSTS=mail.google.com,www.mail.google.com,gmail.com,www.gmail.com
